# Server
PORT=3100
NODE_ENV=development
API_BASE_URL=http://your-ec2-ip:3100

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=noble_msp

# Noble IT (invoice sender info)
NOBLE_IT_NAME=Noble IT
NOBLE_IT_ADDRESS=3654 Thornton Avenue, 1065, Fremont, California 94536
NOBLE_IT_PHONE=8189353040
NOBLE_IT_EMAIL=your@nobleit.com
NOBLE_IT_BILLING_EMAIL=billing@nobleit.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
APPROVAL_EMAIL=your@email.com

# Invoice
INVOICE_PDF_DIR=/var/noble-msp/invoices
PAYMENT_DUE_DAYS=30

# Hardware markup percentage (e.g. 30 = 30%)
HARDWARE_MARKUP_PCT=30

# AWS S3 (for invoice archival). Leave blank in dev — the S3 service no-ops
# when any of these are missing and saveInvoiceToS3 falls back to just
# flipping status to APPROVED.
AWS_REGION=us-west-1
AWS_S3_BUCKET=noble-it-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
